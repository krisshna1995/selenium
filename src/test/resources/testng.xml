<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Master Suite" verbose="1" parallel="methods" thread-count="4">

    <listeners>
        <listener class-name="com.company.automation.core.listeners.TestListener"/>
        <listener class-name="com.company.automation.core.listeners.RetryListener"/>
    </listeners>

    <test name="Smoke Tests">
        <packages>
            <package name="com.company.automation.tests.smoke"/>
        </packages>
    </test>

    <test name="Regression Tests">
        <packages>
            <package name="com.company.automation.tests.regression"/>
        </packages>
    </test>

</suite>
